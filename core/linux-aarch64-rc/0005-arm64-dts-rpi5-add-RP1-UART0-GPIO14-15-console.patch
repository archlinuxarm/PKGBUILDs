From d3e4d23214b4cfa2377fef64f3d7ba5e0c13378a Mon Sep 17 00:00:00 2001
From: John Audia <therealgraysky AT proton DOT me>
Date: Tue, 30 Jun 2026 06:00:18 -0400
Subject: [PATCH 2/2] arm64: dts: rpi5: add RP1 UART0 (GPIO14/15) serial
 console node

---
 arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts | 12 ++++++++++++
 arch/arm64/boot/dts/broadcom/rp1-common.dtsi     | 11 +++++++++++
 2 files changed, 23 insertions(+)

diff --git a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
index 0fc57e72632e..de91f4013368 100644
--- a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
+++ b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
@@ -15,6 +15,7 @@
 / {
 	aliases {
 		ethernet0 = &rp1_eth;
+		serial0 = &rp1_uart0;
 	};
 };
 
@@ -64,6 +65,11 @@ phy1: ethernet-phy@1 {
 };
 
 &rp1_gpio {
+	rp1_uart0_default_state: rp1-uart0-default-state {
+		function = "uart0";
+		groups = "uart0";
+	};
+
 	usb_vbus_default_state: usb-vbus-default-state {
 		function = "vbus1";
 		groups = "vbus1";
@@ -103,3 +109,9 @@ &rp1_usb0 {
 &rp1_usb1 {
 	status = "okay";
 };
+
+&rp1_uart0 {
+	pinctrl-0 = <&rp1_uart0_default_state>;
+	pinctrl-names = "default";
+	status = "okay";
+};
diff --git a/arch/arm64/boot/dts/broadcom/rp1-common.dtsi b/arch/arm64/boot/dts/broadcom/rp1-common.dtsi
index 16f535939583..d029985c0972 100644
--- a/arch/arm64/boot/dts/broadcom/rp1-common.dtsi
+++ b/arch/arm64/boot/dts/broadcom/rp1-common.dtsi
@@ -103,6 +103,17 @@ rp1_i2c6: i2c@40088000 {
 		status = "disabled";
 	};
 
+	rp1_uart0: serial@40030000 {
+		compatible = "arm,pl011-axi";
+		reg = <0x0 0x40030000  0x0 0x100>;
+		interrupts = <25 IRQ_TYPE_LEVEL_HIGH>;
+		clocks = <&rp1_clocks RP1_CLK_UART>,
+			 <&rp1_clocks RP1_PLL_SYS_PRI_PH>;
+		clock-names = "uartclk", "apb_pclk";
+		arm,primecell-periphid = <0x00341011>;
+		status = "disabled";
+	};
+
 	rp1_gpio: pinctrl@400d0000 {
 		compatible = "raspberrypi,rp1-gpio";
 		reg = <0x00 0x400d0000  0x0 0xc000>,
-- 
2.54.0

