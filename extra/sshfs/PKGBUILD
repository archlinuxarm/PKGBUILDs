# ALARM: Kevin Mihelich <kevin@archlinuxarm.org>
#  - use -D_FILE_OFFSET_BITS=64 with 32-bit ARM

pkgname=sshfs
pkgver=3.7.6
pkgrel=1
pkgdesc="FUSE client based on the SSH File Transfer Protocol"
arch=(x86_64)
url="https://github.com/libfuse/sshfs"
license=(GPL-2.0-or-later)
depends=(
  fuse3
  glib2
  glibc
  openssh
)
makedepends=(
  meson
  python-docutils
)
source=(https://github.com/libfuse/sshfs/releases/download/$pkgname-$pkgver/$pkgname-$pkgver.tar.xz{,.asc})
b2sums=('d7a6fc97ef9a9d67d89afbe48272f684b10c3cd70333c73d88d068821bcb9aadaef72599d6c1de1bc114f1ce311e9ecb23f052468e7bde1d6007d28b0b95639a'
        'SKIP')
validpgpkeys=('9C113099DF707BD240A192D4C6E054D074D5DD2B') # Haoxi Tan <h4sh5@pm.me>

build() {
  [[ $CARCH == 'arm' || $CARCH == 'armv6h' || $CARCH == 'armv7h' ]] && export CFLAGS+=" -D_FILE_OFFSET_BITS=64"
  arch-meson $pkgname-$pkgver build
  meson compile -C build
}

package() {
  meson install -C build --destdir "$pkgdir"
}
