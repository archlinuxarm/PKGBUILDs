From 8c763ca5262a7453ffe7a100c318256922b61b39 Mon Sep 17 00:00:00 2001
From: Cary Phillips <cary@ilm.com>
Date: Thu, 26 Feb 2026 14:18:30 -0800
Subject: [PATCH 4/5] Add #if specific to __APPLE__; add better comments

Signed-off-by: Cary Phillips <cary@ilm.com>
---
 src/lib/OpenEXRCore/internal_thread.h | 19 +++++++++++++++----
 1 file changed, 15 insertions(+), 4 deletions(-)

diff --git a/src/lib/OpenEXRCore/internal_thread.h b/src/lib/OpenEXRCore/internal_thread.h
index 1aa7d5c008..2842a6f496 100644
--- a/src/lib/OpenEXRCore/internal_thread.h
+++ b/src/lib/OpenEXRCore/internal_thread.h
@@ -8,10 +8,11 @@
 
 #include "openexr_config.h"
 
-// Thread-safe single initiatization, using InitOnceExecuteOnce on Windows,
-// pthread_once elsewhere, or a simple variable if threading is completely disabled.
 #if ILMTHREAD_THREADING_ENABLED
 #    ifdef _WIN32
+/* On Windows, use native InitOnceExecuteOnce, which avoids MSVC's
+ * problematic <threads.h>
+ */
 #        include <windows.h>
 #        define ONCE_FLAG_INIT INIT_ONCE_STATIC_INIT
 typedef INIT_ONCE once_flag;
@@ -27,7 +28,10 @@ call_once (once_flag* flag, void (*func) (void))
 {
     InitOnceExecuteOnce (flag, once_init_fn, (PVOID) func, NULL);
 }
-#    elif !defined(ONCE_FLAG_INIT)
+#    elif defined(__APPLE__)
+/*
+ * On macOS, use <pthreads.h> and pthread_once.
+ */
 #        include <pthread.h>
 #        define ONCE_FLAG_INIT PTHREAD_ONCE_INIT
 typedef pthread_once_t once_flag;
@@ -36,10 +40,17 @@ call_once (once_flag* flag, void (*func) (void))
 {
     (void) pthread_once (flag, func);
 }
+#    else
+/*
+ * On Linux, use standard <threads.h>
+ */
+#        include <threads.h>
 #    endif
 
 #else /* !ILMTHREAD_THREADING_ENABLED */
-
+/*
+ * Threading disabled, provide a stub call_once.
+ */
 #    ifndef ONCE_FLAG_INIT
 #        define ONCE_FLAG_INIT 0
 typedef int once_flag;

From 5fda77522f8eb08c43aa1f0cae150b8619c16cf4 Mon Sep 17 00:00:00 2001
From: Cary Phillips <cary@ilm.com>
Date: Thu, 26 Feb 2026 14:57:45 -0800
Subject: [PATCH 5/5] replace __APPLE__ with has_include<threads.h>

Signed-off-by: Cary Phillips <cary@ilm.com>
---
 src/lib/OpenEXRCore/internal_thread.h | 32 +++++++++++++++------------
 1 file changed, 18 insertions(+), 14 deletions(-)

diff --git a/src/lib/OpenEXRCore/internal_thread.h b/src/lib/OpenEXRCore/internal_thread.h
index 2842a6f496..d638c2f7f7 100644
--- a/src/lib/OpenEXRCore/internal_thread.h
+++ b/src/lib/OpenEXRCore/internal_thread.h
@@ -10,7 +10,8 @@
 
 #if ILMTHREAD_THREADING_ENABLED
 #    ifdef _WIN32
-/* On Windows, use native InitOnceExecuteOnce, which avoids MSVC's
+/*
+ * On Windows, use native InitOnceExecuteOnce, which avoids MSVC's
  * problematic <threads.h>
  */
 #        include <windows.h>
@@ -28,9 +29,15 @@ call_once (once_flag* flag, void (*func) (void))
 {
     InitOnceExecuteOnce (flag, once_init_fn, (PVOID) func, NULL);
 }
-#    elif defined(__APPLE__)
+#    elif __has_include(<threads.h>)
+/*
+ * On Linux (glibc 2.28+), use standard <threads.h>
+ */
+#        include <threads.h>
+
+#    else
 /*
- * On macOS, use <pthreads.h> and pthread_once.
+ * No <threads.h> on macOS and older Linux distros: fall back to pthreads
  */
 #        include <pthread.h>
 #        define ONCE_FLAG_INIT PTHREAD_ONCE_INIT
@@ -40,19 +47,17 @@ call_once (once_flag* flag, void (*func) (void))
 {
     (void) pthread_once (flag, func);
 }
-#    else
-/*
- * On Linux, use standard <threads.h>
- */
-#        include <threads.h>
+
 #    endif
 
-#else /* !ILMTHREAD_THREADING_ENABLED */
+#endif /* ILMTHREAD_THREADING_ENABLED */
+
 /*
- * Threading disabled, provide a stub call_once.
+ * If threading is disabled, or call_once/ONCE_FLAG_INIT wasn't declared
+ * above, declare a default implementation.
  */
-#    ifndef ONCE_FLAG_INIT
-#        define ONCE_FLAG_INIT 0
+#ifndef ONCE_FLAG_INIT
+#  define ONCE_FLAG_INIT 0
 typedef int once_flag;
 static inline void
 call_once (once_flag* flag, void (*func) (void))
@@ -62,8 +67,7 @@ call_once (once_flag* flag, void (*func) (void))
         func ();
     }
 }
-#    endif
+#endif
 
-#endif /* ILMTHREAD_THREADING_ENABLED */
 
 #endif /* OPENEXR_PRIVATE_THREAD_H */
