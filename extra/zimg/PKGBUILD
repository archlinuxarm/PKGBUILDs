# Maintainer: Maxime Gauduin <alucryd@archlinux.org>
# Contributor: Gustavo Alvarez <sl1pkn07@gmail.com>

# ALARM: Kevin Mihelich <kevin@archlinuxarm.org>
#  - remove --enable-x86simd from configure
#  - configure with --disable-simd

pkgname=zimg
pkgver=3.0.6
pkgrel=2
pkgdesc='Scaling, colorspace conversion, and dithering library'
arch=(x86_64)
url=https://github.com/sekrit-twc/zimg
license=(WTFPL)
depends=(
  glibc
  libgcc
  libstdc++
)
makedepends=(git)
provides=(libzimg.so)
options=(!emptydirs)
source=(git+https://github.com/sekrit-twc/zimg.git#tag=release-${pkgver})
b2sums=('7b1607b5ce81468fc912be8d1c88d57f88834552be4cb778d80e5ca31fd7226d4142d63831f28855361b783cb7810f9355a23038860e6716f1deb3b3f9a9dfc9')

prepare() {
  cd zimg
  ./autogen.sh
}

build() {
  cd zimg
  ./configure \
    --prefix=/usr \
    --disable-static \
    --disable-simd
  make
}

package(){
  make DESTDIR="${pkgdir}" -C zimg install
  install -Dm 644 zimg/COPYING -t "${pkgdir}"/usr/share/licenses/zimg/
}
