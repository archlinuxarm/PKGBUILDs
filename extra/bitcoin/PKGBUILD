prepare() {
  sha256sum -c --ignore-missing "$pkgbase-$pkgver.SHA256SUMS"
  cd $pkgbase-$pkgver
  patch -Np1 -i ../bitcoin-completions.patch
}

build() {
  cd $pkgbase-$pkgver

  # https://gcc.gnu.org/bugzilla/show_bug.cgi?id=125345
  # https://github.com/bitcoin/bitcoin/issues/35282
  export CC=/usr/bin/cc-15
  export CXX=/usr/bin/c++-15

  [[ $CARCH == "aarch64" ]] && CFLAGS=`echo $CFLAGS | sed -e 's/-march=armv8-a/-march=armv8-a+crc+crypto/'` && CXXFLAGS="$CFLAGS"
  cmake -B build -DBUILD_GUI=ON -DBUILD_UTIL_CHAINSTATE=ON -DBUILD_SHARED_LIBS=ON \
    -DCMAKE_BUILD_TYPE=None -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_LIBEXECDIR=lib
  cmake --build build
}

check() {
  cd $pkgbase-$pkgver

  # https://gcc.gnu.org/bugzilla/show_bug.cgi?id=125345
  # https://github.com/bitcoin/bitcoin/issues/35282
  export CC=/usr/bin/cc-15
  export CXX=/usr/bin/c++-15

  ctest --test-dir build --output-on-failure
}

package_bitcoin-qt() {
  pkgdesc="Fully validating Bitcoin peer-to-peer network node - GUI"
  depends=(
    bitcoin-daemon
    capnproto libcapnp.so libcapnp-rpc.so
    glibc
    hicolor-icon-theme
    libevent
    libgcc
    libstdc++ libstdc++.so
    qrencode
    qt6-base
    sqlite libsqlite3.so
  )
  provides=('bitcoin-gui')

  cd $pkgbase-$pkgver
  for tool in bitcoin-qt bitcoin-gui
  do
    DESTDIR="$pkgdir" cmake --install build --component "$tool"
  done

  # desktop files
  install -Dm644 ../bitcoin-qt.desktop \
    "$pkgdir"/usr/share/applications/org.bitcoin.bitcoin-qt.desktop
  install -Dm644 ../bitcoin-qt.appdata.xml \
    "$pkgdir"/usr/share/metainfo/org.bitcoin.bitcoin-qt.appdata.xml
  install -Dm644 src/qt/res/src/bitcoin.svg \
    "$pkgdir"/usr/share/icons/hicolor/scalable/apps/bitcoin-qt.svg

  for i in 16 32 64 128 256; do
    install -Dm644 share/pixmaps/bitcoin${i}.png \
      "$pkgdir"/usr/share/icons/hicolor/${i}x${i}/apps/bitcoin-qt.png
  done

  # license
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

package_bitcoin-daemon() {
  pkgdesc="Fully validating Bitcoin peer-to-peer network node - daemon"
  depends=(
    bitcoin-tx
    capnproto libcapnp.so libcapnp-rpc.so
    glibc
    libevent
    libgcc
    libstdc++ libstdc++.so
    sqlite libsqlite3.so
  )
  backup=('etc/bitcoin/bitcoin.conf')
  provides=('bitcoin-cli')
  replaces=('bitcoin-cli')

  cd $pkgbase-$pkgver
  for tool in bitcoin-cli bitcoind bitcoin-node
  do
    DESTDIR="$pkgdir" cmake --install build --component "$tool"
  done

  # systemd files
  install -Dm644 contrib/init/bitcoind.service \
    "$pkgdir/usr/lib/systemd/system/bitcoind.service"
  install -Dm644 "$srcdir/bitcoin.sysusers" \
    "$pkgdir/usr/lib/sysusers.d/bitcoin.conf"
  install -Dm644 "$srcdir/bitcoin.tmpfiles" \
    "$pkgdir/usr/lib/tmpfiles.d/bitcoin.conf"

  # config files
  install -dm710 "$pkgdir/etc/bitcoin"
  install -Dm644 share/examples/bitcoin.conf \
    "$pkgdir/etc/bitcoin/bitcoin.conf"

  # license
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

package_bitcoin-tx() {
  pkgdesc="Fully validating Bitcoin peer-to-peer network node - commandline tools"
  depends=(
    glibc
    libgcc
    libstdc++ libstdc++.so
    sqlite libsqlite3.so
  )
  provides=(
    libbitcoinkernel.so
  )

  cd $pkgbase-$pkgver
  for tool in bitcoin bitcoin-tx bitcoin-util bitcoin-wallet bitcoin-chainstate libbitcoinkernel
  do
    DESTDIR="$pkgdir" cmake --install build --component "$tool"
  done

  # license
  install -Dm644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

