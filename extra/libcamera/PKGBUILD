pkgbase=libcamera
pkgname=(
  libcamera
  libcamera-docs
  libcamera-ipa
  libcamera-tools
  gst-plugin-libcamera
  python-libcamera
)
pkgver=0.7.2
pkgrel=3
pkgdesc="A complex camera support library for Linux, Android, and ChromeOS"
arch=(x86_64)
url="https://libcamera.org/"
_url=https://git.libcamera.org/libcamera/libcamera.git
makedepends=(
  cmake
  doxygen
  git
  glib2
  graphviz
  gst-plugins-base
  gtest
  libdrm
  libgcc
  libjpeg-turbo
