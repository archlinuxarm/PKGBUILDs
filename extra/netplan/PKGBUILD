prepare() {
  # TODO: fix this upstream!
  # disable searching for Python packages used for testing (by wrong names)
  # disable linting and codestyle tests as they are broken and useless to us
  # disable unit-tests as we run them manually in check() to be able to disable things that are broken
  patch -Np1 -d $pkgname -i ../$pkgname-1.1-disable-tests.patch
  # use /usr/lib instead of /usr/libexec
  patch -Np1 -d $pkgname -i ../$pkgname-0.107-use_lib.patch
  # Arch installs admin binaries into /usr/bin, not /usr/sbin
  sed -i 's#/usr/sbin/netplan#/usr/bin/netplan#g' $pkgname/tests/generator/base.py $pkgname/tests/test_sriov.py $pkgname/tests/integration/regressions.py
  sed -i 's#/usr/sbin/iw#/usr/bin/iw#g' $pkgname/tests/generator/test_wifis.py
}

build() {
  arch-meson $pkgname build
  meson compile -C build
}

check() {
  meson test -C build

  export PYTHONPATH="build/python-cffi:$pkgname"
  export NETPLAN_GENERATE_PATH="$PWD/build/src/generate"
  export NETPLAN_CONFIGURE_PATH="$PWD/build/src/configure"
  export NETPLAN_DBUS_CMD="$PWD/build/dbus/netplan-dbus"
  # DBus subprocess tests leak COVERAGE_PROCESS_START into python startup and
  # fail with coverage sitecustomize import errors in Arch build environments.
  LD_LIBRARY_PATH="build/src" pytest -vv \
    --deselect $pkgname/tests/netplan_dbus/test_dbus.py::TestNetplanDBus::test_netplan_apply_in_snap_calls_busctl \
    --deselect $pkgname/tests/netplan_dbus/test_dbus.py::TestNetplanDBus::test_netplan_apply_in_snap_uses_dbus \
    --deselect $pkgname/tests/netplan_dbus/test_dbus.py::TestNetplanDBus::test_netplan_generate_in_snap_calls_busctl
}

package() {
  meson install -C build --destdir "$pkgdir"
}
