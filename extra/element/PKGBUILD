#  - disable distcc - configure checks for clang first

highmem=1

pkgname=element
pkgver=1.0.0
pkgrel=1
pkgdesc="A modular audio plugin host"
arch=(x86_64)
url="https://github.com/kushview/element"
license=(GPL-3.0-or-later)
groups=(pro-audio)
options=(!distcc)
depends=(
  alsa-lib
  fontconfig
  freetype2
  glibc
  hicolor-icon-theme
  libgcc
  libstdc++
)
makedepends=(
  boost
  clang
  cmake
  curl
  git
  gtk3
  jack
  juce
  ladspa
  ldoc
  libglvnd
  libxcomposite
  libxcursor
  libxinerama
  lv2
  ttf-roboto
  webkit2gtk
  xorg-xrandr
)
# TODO: package sol2 for lua support
# optdepends=('lua: for LUA scripting')
provides=(
  ladspa-host
  lv2-host
  vst3-host
)
source=(
  git+https://github.com/kushview/$pkgname#tag=$pkgver
  git+https://github.com/free-audio/clap-juce-extensions.git
  git+https://github.com/free-audio/clap.git  # submodule of clap-juce-extensions
  git+https://github.com/free-audio/clap-helpers.git  # submodule of clap-juce-extensions
)
sha512sums=('288ecdfffe85edbfd5841e6323c347a574ebcba4f5c454f4825c7f249f4895487bedbca8093f67f6b187fe52f0120b3cd7eee22e978f224a7c163fe475e2babc'
            'SKIP'
            'SKIP'
            'SKIP')
b2sums=('78b7839e1274898775a3268a5b87b5e90f3cfe0ef59e1d31d0d94599d7633e030277c4e9d91da33bd7d6cb583e5f383fbc44569cb042c5052487ffa32a1444d7'
        'SKIP'
        'SKIP'
        'SKIP')

prepare() {
  cd $pkgname
  git submodule init
  git config submodule.deps/clap-juce-extensions.url "$srcdir/clap-juce-extensions"
  git config submodule.deps/clap-juce-extensions.url "$srcdir/clap-juce-extensions"
  git -c protocol.file.allow=always submodule update

  cd deps/clap-juce-extensions
  git submodule init
  git config submodule.clap-libs/clap.url "$srcdir/clap"
  git config sbumodule.clap-libs/clap-helpers.url "$srcdir/clap-helpers"
  git -c protocol.file.allow=always submodule update
}

build() {
  local cmake_options=(
    -B build
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/usr
    -S $pkgname
    -W no-dev
  )

  cmake "${cmake_options[@]}"
  cmake --build build --verbose
}

check() {
  local ctest_flags=(
    --test-dir build
    # show the stdout and stderr when the test fails
    --output-on-failure
    # execute tests in parallel
    --parallel "$(nproc)"
  )
  ctest "${ctest_flags[@]}"
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -vDm 644 $pkgname/{AUTHORS,CHANGELOG,CODE_OF_CONDUCT,CONTRIBUTING,README}.md -t "$pkgdir/usr/share/doc/$pkgname/"
}
