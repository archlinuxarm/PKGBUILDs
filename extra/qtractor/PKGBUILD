pkgname=qtractor
pkgver=1.6.1
pkgrel=2
pkgdesc="Audio/MIDI multitrack sequencer"
arch=(x86_64)
url="https://qtractor.sourceforge.io/"
license=(GPL-2.0-or-later)
groups=(pro-audio)
depends=(
  glibc
  hicolor-icon-theme
  libgcc
  libmad
  libstdc++
  libxcb
  qt6-base
  qt6-svg
  zlib
)
makedepends=(
  alsa-lib
  clap
  cmake
  dssi
  git
  jack
  ladspa
  liblo
  libogg
  libsamplerate
  libsndfile
  libvorbis
  lilv
  lv2
  qt6-tools
  rubberband
  suil
  vst3sdk
)
optdepends=(
  'new-session-manager: for session management'
)
provides=(
  clap-host
  dssi-host
  ladspa-host
  lv2-host
  vst-host
  vst3-host
)
source=(
  $pkgname::git+https://github.com/rncbc/qtractor.git#tag=v$pkgver
  minibpm::git+https://github.com/breakfastquay/minibpm.git
)
sha512sums=('66e904ce50b6880a8aef6af0758e5f7a44e0abcc49cacf841f14dedc95093b1453417fcd290f92ecde12f1307fd8e096636041d0fdc5cf646578ad50dfff9eb8'
            'SKIP')
b2sums=('3b55b4bdb48fbe779f40f7ac9679efc8bda99dbbb82ad91dc92f596a987ac361b3c89488a56cc606049ae9a01142db18caedb418f4281802e7e912a0dbb4fdf0'
        'SKIP')

prepare() {
  cd $pkgname
  git submodule init
  git config submodule.src/minibpm.url "$srcdir/minibpm"
  git submodule deinit src/clap
  git submodule deinit src/vst3/base
  git submodule deinit src/vst3/pluginterfaces
  git submodule deinit src/vst3/public.sdk
  git -c protocol.file.allow=always submodule update

  # symlink vst3sdk into place
  rm -frv src/vst3
  ln -fsv /usr/src/vst3sdk/ src/vst3
}

build() {
  local cmake_options=(
    -B build
    -D CMAKE_BUILD_TYPE=None
    -D CMAKE_INSTALL_PREFIX=/usr
    -D CONFIG_QT6=ON
    -D CONFIG_SSE=OFF
    -D CONFIG_LV2_UI_GTK2=OFF
    -D CONFIG_LV2_UI_GTKMM2=OFF
    -S $pkgname
    -W no-dev
  )

  cmake "${cmake_options[@]}"
  cmake --build build --verbose
}

package() {
  depends+=(
    alsa-lib libasound.so
    jack libjack.so
    liblo liblo.so
    libogg libogg.so
    libsamplerate libsamplerate.so
    libsndfile libsndfile.so
    libvorbis libvorbisenc.so libvorbisfile.so libvorbis.so
    lilv liblilv-0.so
    rubberband librubberband.so
  )

  DESTDIR="$pkgdir" cmake --install build
  install -vDm 644 $pkgname/README* -t "$pkgdir/usr/share/doc/$pkgname/"
}
