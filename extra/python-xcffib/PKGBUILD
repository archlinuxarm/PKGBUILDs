# Contributor: Roger Duran <rogerduran@gmail.com>

# ALARM: dequis <dx@dxzone.com.ar>
#  - remove haskell-xcffib dependency by using the pypi release instead

pkgname=python-xcffib
pkgver=1.6.2
pkgrel=1
pkgdesc="xcffib is the XCB binding for python"
arch=('any')
url="https://pypi.python.org/pypi/xcffib"
license=('Apache-2.0')
depends=('python-cffi' 'libxcb')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
checkdepends=('python-pytest' 'xorg-server-xvfb' 'xorg-xeyes')
_name=${pkgname#python-}
source=("https://files.pythonhosted.org/packages/source/${_name::1}/$_name/$_name-$pkgver.tar.gz")
sha512sums=('c19ca9adf3649ee1497745b76c3e08f6850446f8a0ee0e4024dc3333c0edf72474e1fcb18b09ac69ade475c48780c9cb005042c8dfb0ba2d32a21a7c5efeabb4')

prepare() {
  touch xcffib-$pkgver/test/__init__.py
}

build() {
  cd xcffib-$pkgver
  python -m build --wheel --no-isolation
}

check() {
  cd xcffib-$pkgver
  xvfb-run pytest
}

package() {
  cd xcffib-$pkgver
  python -m installer --destdir="$pkgdir" dist/*.whl
}
