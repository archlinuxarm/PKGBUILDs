pkgbase = ldc
	pkgdesc = A D Compiler based on the LLVM Compiler Infrastructure including D runtime and libphobos2
	pkgver = 1.42.0
	pkgrel = 1
	epoch = 3
	url = https://github.com/ldc-developers/ldc
	arch = x86_64
	groups = dlang
	groups = dlang-ldc
	license = BSD-3-Clause AND BSL-1.0 AND Apache-2.0 WITH LLVM-exception
	makedepends = git
	makedepends = cmake
	makedepends = llvm21
	makedepends = lld
	makedepends = ldc
	makedepends = ninja
	options = !lto
	source = git+https://github.com/ldc-developers/ldc#commit=3d5bafdf0e6f0d4619f04baad80d2b8afb6ba8ad
	source = ldc-phobos::git+https://github.com/ldc-developers/phobos.git
	sha256sums = c30b46ce86759290cc2fc7e9da3357fa34a322a78c079b43876f7f0d935f3c1a
	sha256sums = SKIP

pkgname = ldc
	depends = liblphobos
	depends = llvm21-libs
	depends = gcc
	depends = compiler-rt21
	depends = curl
	provides = d-compiler=2.112.1
	backup = etc/ldc2.conf

pkgname = liblphobos
	depends = curl
	provides = d-runtime
	provides = d-stdlib
	options = staticlibs
