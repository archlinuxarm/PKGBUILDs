pkgname=netperf
pkgver=2.7.0
pkgrel=8
pkgdesc='Benchmarking tool for many different types of networking'
url='https://github.com/HewlettPackard/netperf/'
license=(MIT BSD-3-Clause BSD-4-Clause)
arch=('x86_64')
depends=('glibc' 'lksctp-tools')
install=netperf.install
source=("https://github.com/HewlettPackard/netperf/archive/$pkgname-$pkgver.tar.gz"
        'netserver.service'
        '001-fix-inlining.patch'
        0b0cbbef75021134c83be0c3dd21878467e11144.patch
        https://github.com/HewlettPackard/netperf/commit/358c13f4dd542f9d60afd454ffa48d02214b1e59.patch)
sha224sums=('6ab49c94d6231d4848bc43c8d56ad4a2611862f800a61009f3b2f2fe'
            'c5c48a480d62e82d1e65cc3ef8472864bf12d2cc527d6a9c12dca613'
            '7a30925a46ab5e40ccc2b966a5d7e57a15967b9116c8773cd75030f5'
            'fb914387dbaf2620fb243bece5513ca56f15066ff9314a4f3ef76f51'
            'c65ee34bb1464c4dacfcafc8165692cd8d9b934bcb55f573979b0aa8')

prepare() {
  cd netperf-netperf-$pkgver
  # apply patch from the source array (should be a pacman feature)
  local src
  for src in "${source[@]}"; do
    src="${src%%::*}"
    src="${src##*/}"
    [[ $src = *.patch ]] || continue
    msg2 "Applying patch $src..."
    patch -Np1 < "../$src"
  done
  :
  ./autogen.sh
}

build() {
  cd netperf-netperf-$pkgver
  CFLAGS+=' -fcommon -std=c99' # https://wiki.gentoo.org/wiki/Gcc_10_porting_notes/fno_common
  ./configure \
    --prefix=/usr \
    --enable-demo \
    --enable-unixdomain \
    --enable-dccp \
    --enable-sctp
  make
}

package() {
  cd netperf-netperf-$pkgver
  make DESTDIR="$pkgdir" install
  # license
  install -D -m 644 COPYING "$pkgdir/usr/share/licenses/$pkgname/COPYING"
  # systemd
  install -D -m 644 {..,"$pkgdir"/usr/lib/systemd/system}/netserver.service
}

