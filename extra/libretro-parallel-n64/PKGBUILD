# Maintainer: Maxime Gauduin <alucryd@archlinux.org>
# Contributor: Thomas Schneider <maxmusterm@gmail.com>

# ALARM: Kevin Mihelich <kevin@archlinuxarm.org>
#  - set WITH_DYNAREC for ARM

pkgname=libretro-parallel-n64
pkgver=20260626.052303.g60817554d605
pkgrel=1
pkgdesc='Nintendo 64 core'
arch=(x86_64)
url=https://github.com/libretro/parallel-n64
license=(GPL-2.0-only)
groups=(libretro)
depends=(
  glibc
  libgcc
  libgl
  libretro-core-info
  libstdc++
)
makedepends=(
  git
  mesa
  nasm
)
source=(libretro-parallel-n64::git+https://github.com/libretro/parallel-n64.git#commit=${pkgver##*.g})
b2sums=('c7f9688ac319a5c5ee7fb0ea356b3c54340ee19b64e97782e9555edc136a45dee24c0b1187ad6789060e53b53e72e3cd77556c25ffe6c073e43cc8a7926f2687')
options=(!lto)

build() {
  export CFLAGS+=' -Wno-implicit-function-declaration'
  export CXXFLAGS+=' -Wno-implicit-function-declaration'
  make -C libretro-parallel-n64 \
    WITH_DYNAREC=$([[ $CARCH == aarch64 ]] && echo aarch64 || echo arm) \
    HAVE_PARALLEL=1 \
    HAVE_PARALLEL_RSP=1 \
    HAVE_THR_AL=1
}

package() {
  install -Dm 644 libretro-parallel-n64/parallel_n64_libretro.so -t "${pkgdir}"/usr/lib/libretro/
}
