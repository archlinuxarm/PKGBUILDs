# ALARM: Kevin Mihelich <kevin@archlinuxarm.org>
#  - remove dlib-cuda package, cuda and cudnn makedepends

pkgname=dlib
pkgver=20.0.1
pkgrel=2
pkgdesc='Machine learning library and toolkit'
arch=(x86_64)
url='http://dlib.net'
license=(BSL-1.0)
depends=(blas cblas ffmpeg giflib lapack libjpeg-turbo libjxl libpng libwebp libx11 sqlite)
makedepends=(cmake git)
options=(!debug !emptydirs !lto)
source=("git+https://github.com/davisking/dlib#tag=v$pkgver")
b2sums=('c8dd5bf2c0c9222b25c202f3c8425fa07fbb81aac6ea7c1104d638ad5d8f477104ea3f5fa21640f1e9c10ba2d79861c98a6a944a53d895ceda0a04bbc0954c21')

build() {
  cmake \
    -B build \
    -D BUILD_SHARED_LIBS=ON \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_INSTALL_LIBDIR=/usr/lib \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D DLIB_USE_CUDA=OFF \
    -D USE_AVX_INSTRUCTIONS=OFF \
    -D USE_SSE2_INSTRUCTIONS=ON \
    -S $pkgname
  make -C build
}

package() {
  provides=(dlib)
  conflicts=(dlib)

  make -C build DESTDIR="$pkgdir" install
  install -Dm644 $pkgbase/LICENSE.txt \
    "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  # remove redundant external libraries
  rm -r "$pkgdir/usr/include/dlib/external"
}
