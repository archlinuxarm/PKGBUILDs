# Maintainer: graysky <therealgraysky AT proton DOT me>
# Contributor: Nick Hainke <vincent@systemli.org>

buildarch=8
pkgbase=raspberry-pi5-armstub
pkgname=(raspberry-pi5-c0-armstub raspberry-pi5-d0-armstub)
pkgver=20240918
_commit=fc45bc492dd655f9ea4893a384527341a48cf03d
pkgrel=4
pkgdesc="ARM Trusted Firmware BL31 and mainline boot config for Raspberry Pi 5"
arch=(aarch64)
url="https://github.com/raspberrypi/arm-trusted-firmware"
license=(BSD-3-Clause)
depends=(raspberrypi-bootloader raspberrypi-overlays)
options=(!strip !buildflags)
source=("arm-trusted-firmware-${_commit:0:10}.tar.gz::https://github.com/raspberrypi/arm-trusted-firmware/archive/${_commit}.tar.gz"
        'config-c0.txt'
        'config-d0.txt'
        'cmdline.txt')
sha256sums=('53478def88dbd35f7600d75ab7f7444a48b68fb2b380ef2145ce99812d8c80d0'
            'fcc4edbb7115436403bc3517dec1dd81d329d3d5c72a45d396d974a4cb431de6'
            'c0fcf8a4551cd81940e62d08f0be0b7db19d57b333851c11b27877ef09247f93'
            'a6f0dc7b9b89bf0e6b0098e0f22d986940486c828f9e8d0e14b333855f5d1ce6')

build() {
  cd "arm-trusted-firmware-${_commit}"
  make PLAT=rpi5 bl31
}

_install_common() {
  install -Dm644 "${srcdir}/arm-trusted-firmware-${_commit}/build/rpi5/release/bl31.bin" \
    "${pkgdir}/boot/armstub8-2712.bin"
  install -Dm644 "${srcdir}/cmdline.txt" "${pkgdir}/boot/cmdline.txt"
}

package_raspberry-pi5-c0-armstub() {
  pkgdesc="ARM Trusted Firmware BL31 and boot config for Raspberry Pi 5 (C0 stepping)"
  provides=(raspberry-pi5-armstub)
  conflicts=(raspberry-pi5-armstub raspberry-pi5-d0-armstub linux-rpi linux-rpi-16k uboot-raspberrypi)
  backup=(boot/config.txt boot/cmdline.txt)
  _install_common
  install -Dm644 "${srcdir}/config-c0.txt" "${pkgdir}/boot/config.txt"
}

package_raspberry-pi5-d0-armstub() {
  pkgdesc="ARM Trusted Firmware BL31 and boot config for Raspberry Pi 5 (D0 stepping)"
  provides=(raspberry-pi5-armstub)
  conflicts=(raspberry-pi5-armstub raspberry-pi5-c0-armstub linux-rpi linux-rpi-16k uboot-raspberrypi)
  backup=(boot/config.txt boot/cmdline.txt)
  _install_common
  install -Dm644 "${srcdir}/config-d0.txt" "${pkgdir}/boot/config.txt"
}
