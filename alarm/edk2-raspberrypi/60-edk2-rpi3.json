{
    "description": "UEFI firmware for raspi3* aarch64",
    "interface-types": [
        "uefi"
    ],
    "mapping": {
        "device": "flash",
        "nvram-template": {
            "filename": "/usr/share/edk2/aarch64/RPi3_EFI.fd",
            "format": "raw"
        }
    },
    "targets": [
        {
            "architecture": "aarch64",
            "machines": [
                "raspi3*"
            ]
        }
    ],
    "features": [
        "verbose-static"
    ],
    "tags": []
}