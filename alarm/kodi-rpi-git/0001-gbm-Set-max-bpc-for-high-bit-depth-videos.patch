From 0b4b2c69558ac3f5582029d580266f10138f5401 Mon Sep 17 00:00:00 2001
From: Dom Cobley <popcornmix@gmail.com>
Date: Fri, 3 Dec 2021 16:00:50 +0000
Subject: [PATCH 1/3] gbm: Set max bpc for high bit depth videos

---
 .../HwDecRender/VideoLayerBridgeDRMPRIME.cpp               | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/VideoLayerBridgeDRMPRIME.cpp b/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/VideoLayerBridgeDRMPRIME.cpp
index d4b94dbf01cc..9b8eb786e6aa 100644
--- a/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/VideoLayerBridgeDRMPRIME.cpp
+++ b/xbmc/cores/VideoPlayer/VideoRenderers/HwDecRender/VideoLayerBridgeDRMPRIME.cpp
@@ -32,6 +32,13 @@ CVideoLayerBridgeDRMPRIME::~CVideoLayerBridgeDRMPRIME()

 void CVideoLayerBridgeDRMPRIME::Disable()
 {
+  // reset max bpc back to default of 8
+  int bpc = 8;
+  auto connector = m_DRM->GetConnector();
+  bool result = m_DRM->AddProperty(connector, "max bpc", bpc);
+  CLog::Log(LOGDEBUG, "CVideoLayerBridgeDRMPRIME::{} - setting max bpc to {} ({})",
+            __FUNCTION__, bpc, result);
+
   auto plane = m_DRM->GetVideoPlane();
   if (!plane)
     return;
