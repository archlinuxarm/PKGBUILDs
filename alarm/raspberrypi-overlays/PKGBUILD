# Maintainer: graysky <therealgraysky AT proton DOT me>
# Contributor: Nick Hainke <vincent@systemli.org>

buildarch=8
pkgname=raspberrypi-overlays
pkgver=20260611
_commit=084c7f66350fd98c37deef6372197a9d9fbb3625
pkgrel=2
pkgdesc="Device tree overlays for Raspberry Pi"
arch=(any)
url="https://github.com/raspberrypi/firmware"
license=(custom)
makedepends=(dtc)
conflicts=(linux-rpi linux-rpi-16k)
options=(!strip)
source=("firmware-$pkgver-${_commit:0:10}.tar.gz::https://github.com/raspberrypi/firmware/archive/${_commit}.tar.gz"
        'bcm2712d0-overlay.dts')
sha256sums=('20979a1b2fd8e7c1b8329ae2e63dfd5b1157b6499c47b562bef561e56045fb76'
            'ed58d0cb3a1a66a753ed8cb954cbe4bc8f09bcbfe7555893561f73c0c99053ab')

package() {
  local _fw="${srcdir}/firmware-${_commit}"

  install -d "${pkgdir}/boot/overlays"
  cp "${_fw}"/boot/overlays/*.dtbo "${pkgdir}/boot/overlays/"
  cp "${_fw}"/boot/overlays/README "${pkgdir}/boot/overlays/"

  # Replace with mainline-compatible version: upstream bcm2712d0.dtbo references
  # &spi10 and &dma40 absent from the mainline BCM2712 symbol table, causing the
  # GPU firmware to abort the overlay and leave D0 silicon with C0 pinctrl
  # addresses, resulting in a kernel panic.
  dtc -I dts -O dtb -@ -W no-unit_address_vs_reg \
      -o "${pkgdir}/boot/overlays/bcm2712d0.dtbo" \
      "${srcdir}/bcm2712d0-overlay.dts"

  install -Dm644 "${_fw}/boot/LICENCE.broadcom" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENCE.broadcom"
}
